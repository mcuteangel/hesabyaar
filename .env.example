# Hesabyar Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Release signing configuration
# Generate a keystore with: ./gradlew generateKeystore
# Or manually: keytool -genkey -v -keystore my-upload-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias <KEY_ALIAS>
KEYSTORE_PASSWORD=YOUR_KEYSTORE_PASSWORD
KEY_ALIAS=YOUR_KEY_ALIAS
KEY_PASSWORD=YOUR_KEY_PASSWORD

# Gemini API key (obtain from https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
